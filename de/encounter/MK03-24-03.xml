            <ability name="Wis" score="10" bonus="+0"/>
            <ability name="Cha" score="8" bonus="-1"/>
        </abilities>
        <traits>
            <trait name="Eisiger Griff">
                <description>Wenn der Gelehrte einen Gegner mit einem Gelegenheitsangriff trifft, sinkt dessen Geschwindigkeit für den Rest des Zuges auf 0.</description>
            </trait>
            <trait name="Untote Standhaftigkeit">
                <description>Falls Schaden die Trefferpunkte des Gelehrten auf 0 reduziert, muss er einen Rettungswurf auf Konstitution gegen einen SG von 5 + erlittener Schaden ablegen, außer der Schaden ist gleißend oder ein kritischer Treffer. Bei einem Erfolg sinken die Trefferpunkte stattdessen nur auf 1.</description>
            </trait>
        </traits>
        <actions>
            <action name="Grabeshauch (Wiederaufladung 5-6)">
                <description>Der Gelehrte stößt eisigen Nebel in einem 4,5 m Kegel aus. Jede Kreatur in diesem Bereich muss einen DC 13 Konstitutionsrettungswurf ablegen. Bei einem Misserfolg erleidet das Ziel 10 (3d6) Kälteschaden und ist bis zum Ende seines nächsten Zuges festgesetzt (Restrained). Bei einem Erfolg erleidet es nur halben Schaden.</description>
            </action>
        </actions>
        <attacks>
            <attack name="Verrostete Klinge">
                <type>Nahkampf</type>
                <bonus>+5</bonus>
                <range>1,5 m</range>
                <target>ein Ziel</target>
                <damage>8 (1d10 + 3) Schlagschaden plus 3 (1d6) nekrotischer Schaden</damage>
            </attack>
        </attacks>
