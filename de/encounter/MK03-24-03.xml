        </skills>
        <traits>
            <trait name="Schutz-Aura">
                <description>Solange Elara bei Bewusstsein ist, erhalten sie und alle befreundeten Kreaturen innerhalb von 3m einen Bonus auf Rettungswürfe in Höhe ihres Charismamodifikators (+5).</description>
            </trait>
            <trait name="Meisterschaft schwerer Waffen">
                <description>Bei einem kritischen Treffer oder wenn sie eine Kreatur auf 0 TP reduziert, kann Elara als Bonusaktion einen Nahkampfangriff ausführen. Vor einem Angriff mit einer schweren Waffe kann sie wählen, einen Malus von -5 auf den Trefferwurf zu nehmen, um +10 auf den Schaden zu erhalten.</description>
            </trait>
            <trait name="Göttliches Gespür (3/Tag)">
                <description>Als Aktion kann Elara die Position von Himmlischen, Teuflischen und Untoten sowie geweihten/entweihten Orten in einem Umkreis von 18m spüren.</description>
            </trait>
        </traits>
        <actions>
            <action name="Mehrfachangriff">
                <description>Elara führt zwei Nahkampfangriffe aus.</description>
            </action>
            <action name="Handauflegen (30 TP)">
                <description>Elara kann eine Kreatur berühren und Trefferpunkte aus einem Pool von 30 TP regenerieren oder eine Krankheit/ein Gift heilen (kostet 5 TP aus dem Pool).</description>
            </action>
            <action name="Göttliche Macht fokussieren: Heilige Waffe">
                <description>Für 1 Minute addiert Elara +2 auf Angriffswürfe mit ihrer Waffe. Die Waffe leuchtet und zählt als magisch.</description>
            </action>
            <action name="Göttliche Macht fokussieren: Die Unheiligen vertreiben">
                <description>Teuflische und Untote im Umkreis von 9m müssen einen Weisheitsrettungswurf (SG 13) bestehen oder werden für 1 Minute vertrieben.</description>
            </action>
        </actions>
        <attacks>
            <attack name="Zweihänder">
                <type>Nahkampf</type>
                <bonus>+5</bonus>
                <range>1,50 m</range>
                <target>ein Ziel</target>
                <damage>10 (2W6 + 3) Hiebschaden</damage>
            </attack>
        </attacks>
        <spellcasting>
            <stat>Cha</stat>
            <saveDC>13</saveDC>
            <attackBonus>+5</attackBonus>
            <spelllist>
                <spell id="ID_D4T_SPELL_BLESS" level="1">Segnen</spell>
                <spell id="ID_D4T_SPELL_DIVINE_FAVOR" level="1">Göttliche Gunst</spell>
                <spell id="ID_D4T_SPELL_CURE_WOUNDS" level="1">Wunden heilen</spell>
                <spell id="ID_D4T_SPELL_AID" level="2">Beistand</spell>
