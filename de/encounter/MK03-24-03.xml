        <kampagne>MK03 - Machtkampf im Orden der Gerüchte</kampagne>
    </info>
    <statblock name="Untote Monstrosität" id="untote-monstrositaet">
        <meta>
            <size>Groß</size>
            <type>Untote</type>
            <alignment>neutral böse</alignment>
            <ac>8</ac>
            <hp>85 (9W10 + 36)</hp>
            <speed>9 m</speed>
            <initiative>-2</initiative>
            <senses>Dunkelsicht 18 m, Passive Wahrnehmung 8</senses>
            <languages>versteht Tyrianisch und Riesisch, kann aber nicht sprechen</languages>
            <challenge>2</challenge>
            <resistances/>
            <immunities>Gift</immunities>
            <conditionImmunities>Vergiftet</conditionImmunities>
        </meta>
        <abilities>
            <ability name="Str" score="19" bonus="+4"/>
            <ability name="Dex" score="6" bonus="-2"/>
            <ability name="Con" score="18" bonus="+4"/>
            <ability name="Int" score="3" bonus="-4"/>
            <ability name="Wis" score="6" bonus="-2"/>
            <ability name="Cha" score="5" bonus="-3"/>
        </abilities>
        <saves>
            <save ability="Wis" bonus="+0"/>
        </saves>
        <skills>
  </skills>
        <traits>
            <trait name="Untote Zähigkeit">
                <description>Sinkt die Untote Monstrosität durch Schaden auf 0 Trefferpunkte, muss sie einen Konstitutionsrettungswurf mit einem SG von 5 + dem erlittenen Schaden ablegen, sofern der Schaden nicht gleißend ist oder von einem kritischen Treffer stammt. Bei Erfolg sinken ihre Trefferpunkte stattdessen auf 1.</description>
            </trait>
        </traits>
        <actions>
            <action name="Morgenstern">
                <description>Nahkampfangriff: +6 auf Treffer, Reichweite 1,50 m, ein Ziel. Treffer: 13 (2W8 + 4) Wuchtschaden.</description>
            </action>
            <action name="Trampeln durch die Barrikade">
                <description>Wenn die Monstrosität sich in gerader Linie mindestens 6 m auf einen Wagen zubewegt, verursacht sie beim ersten Treffer +7 (2W6) Schaden.</description>
            </action>
        </actions>
        <attacks>
            <attack name="Morgenstern">
                <type>Nahkampf</type>
                <bonus>+6</bonus>
                <range>1,50 m</range>
                <target>ein Ziel</target>
                <damage>13 (2W8 + 4) Wuchtschaden</damage>
            </attack>
        </attacks>
