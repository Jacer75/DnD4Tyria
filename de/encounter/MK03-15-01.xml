    <statblock name="Clara Weidenhof" id="d4t-clara-weidenhof">
        <meta>
            <size>Mittel</size>
            <type>Humanoid (Mensch)</type>
            <alignment>rechtschaffen böse</alignment>
            <ac>15 (Kettenhemd)</ac>
            <hp>41 (5W8 + 10)</hp>
            <speed>9 m</speed>
            <initiative>+0</initiative>
            <senses>Passive Wahrnehmung 13</senses>
            <languages>Tyrianisch, Mursaatisch</languages>
            <challenge>4</challenge>
        </meta>
        <abilities>
            <ability name="Str" score="9" bonus="-1"/>
            <ability name="Dex" score="11" bonus="+0"/>
            <ability name="Con" score="14" bonus="+2"/>
            <ability name="Int" score="13" bonus="+1"/>
            <ability name="Wis" score="16" bonus="+3"/>
            <ability name="Cha" score="16" bonus="+3"/>
        </abilities>
        <saves>
            <save ability="Wis" bonus="+6"/>
            <save ability="Cha" bonus="+6"/>
        </saves>
        <skills>
            <skill name="Täuschen" bonus="+6"/>
            <skill name="Motiv erkennen" bonus="+6"/>
            <skill name="Überzeugen" bonus="+6"/>
            <skill name="Heimlichkeit" bonus="+3"/>
        </skills>
        <traits>
            <trait name="Schauspieler (Actor)">
                <description>Clara hat Vorteil auf Charismawürfe (Täuschen) und Charismawürfe (Auftreten), wenn sie versucht, sich als eine andere Person auszugeben. Sie kann die Stimme einer anderen Person oder Geräusche anderer Kreaturen nachahmen, wenn sie diese mindestens 1 Minute lang gehört hat. Ein Zuhörer kann mit einem erfolgreichen Weisheitswurf (Motiv erkennen), der gegen Claras Charismawurf (Täuschen) konkurriert, erkennen, dass die Nachahmung gefälscht ist.</description>
            </trait>
            <trait name="Göttliche Macht fokussieren (Channel Divinity) (1/Kurze Rast)">
                <description>Clara kann ihre Göttliche Macht fokussieren, um Untote zu vertreiben oder ein illusorisches Abbild zu beschwören.</description>
            </trait>
            <trait name="Segen der List (Blessing of the Trickster)">
                <description>Clara kann als Aktion eine andere Kreatur berühren, um ihr 1 Stunde lang Vorteil auf Geschicklichkeitswürfe (Heimlichkeit) zu gewähren.</description>
            </trait>
            <trait name="Ungebrochener Wille (1/Lange Rast)">
                <description>Nachdem Clara einen Angriffs-, Fertigkeits- oder Rettungswurf verfehlt hat, kann sie diesen Wurf als Reaktion wiederholen. Sie muss das neue Ergebnis verwenden.</description>
            </trait>
        </traits>
        <actions>
            <action name="Göttliche Macht fokussieren: Abbild beschwören (Invoke Duplicity) ">
                <description>Clara erschafft für 1 Minute ein perfektes illusorisches Doppel von sich innerhalb von 9 m (30 feet). Als Bonusaktion kann sie das Abbild bis zu 9 m (30 feet) bewegen, solange es sich innerhalb von 36 m (120 feet) befindet. Clara kann Zauber wirken, als befände sie sich im Raum des Abbilds. Wenn sowohl Clara als auch ihr Abbild sich innerhalb von 1,5 m (5 feet) eines Gegners befinden, hat Clara Vorteil auf Angriffswürfe gegen dieses Ziel, sofern das Abbild und Clara den Angriffswurf sehen können.</description>
            </action>
            <action name="Göttliche Macht fokussieren: Untote vertreiben (Turn Undead)">
                <description>Jeder Untote im Umkreis von 9 m (30 feet), der Clara sehen oder hören kann, muss einen Weisheitsrettungswurf SG 14 ablegen. Bei einem Misserfolg ist er 1 Minute lang oder bis er Schaden erleidet vertrieben. Vertriebene Kreaturen müssen sich so weit wie möglich von Clara entfernen, können sich ihr nicht freiwillig auf 9 m (30 feet) nähern, keine Reaktionen einsetzen und dürfen nur Rennen oder Ausweichen nutzen. (Untote vernichten) Wenn ein Untoter mit HG 1/2 oder niedriger bei Claras Untote vertreiben den Rettungswurf verfehlt, wird er sofort vernichtet.</description>
            </action>
        </actions>
        <attacks>
            <attack name="Kampfstab (Quarterstaff)">
                <type>Nahkampf</type>
                <bonus>+2</bonus>
                <range>1,5 m</range>
                <target>ein Ziel</target>
                <damage>1W6 - 1 Wuchtschaden</damage>
            </attack>
        </attacks>
        <!--<bonusactions>
