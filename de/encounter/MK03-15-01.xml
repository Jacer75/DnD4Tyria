    <statblock name="Kenjiro Takahane" id="d4t-kenjiro-takahane">
        <meta>
            <size>Mittel</size>
            <type>Humanoid (Mensch)</type>
            <alignment>rechtschaffen neutral</alignment>
            <ac>16 (Kettenrüstung)</ac>
            <!-- Rüstungsklasse des NSC -->
            <hp>44 (5W10 + 10)</hp>
            <!-- Trefferpunkte inklusive Würfelangabe -->
            <speed>9 m</speed>
            <!-- Bewegungsrate in Metern -->
            <initiative>+1</initiative>
            <!-- Finaler Initiativbonus, der direkt gewürfelt wird -->
            <senses>Passive Wahrnehmung 15</senses>
            <!-- Passive Sinne wie Wahrnehmung, ggf. ergänzt um Dunkelsicht etc. -->
            <languages>Tyrianisch, Canthanisch</languages>
            <!-- Gesprochene Sprachen -->
            <challenge>3</challenge>
            <!-- Herausforderungsgrad -->
            <resistances/>
            <!-- Schadensresistenzen als Klartext -->
            <immunities/>
            <!-- Schadensimmunitäten -->
            <conditionImmunities/>
            <!-- Zustandsimmunitäten -->
        </meta>
        <abilities>
            <ability name="Str" score="16" bonus="+3"/>
            <ability name="Dex" score="13" bonus="+1"/>
            <ability name="Con" score="15" bonus="+2"/>
            <ability name="Int" score="11" bonus="+0"/>
            <ability name="Wis" score="14" bonus="+2"/>
            <ability name="Cha" score="9" bonus="-1"/>
            <!-- Attributswerte mit explizitem Modifikator -->
        </abilities>
        <saves>
            <!-- Rettungswürfe, falls der NSC darin geübt ist -->
            <save ability="Str" bonus="+6"/>
            <save ability="Con" bonus="+5"/>
        </saves>
        <skills>
            <!-- Fertigkeiten mit Bonus, z. B. Heimlichkeit, Wahrnehmung -->
            <skill name="Athletik" bonus="+6"/>
            <skill name="Motiv erkennen" bonus="+5"/>
            <skill name="Einschüchtern" bonus="+2"/>
            <skill name="Wahrnehmung" bonus="+5"/>
        </skills>
        <traits>
            <!-- Passive Eigenschaften oder dauerhafte Sonderregeln -->
            <trait name="Magiertöter (Mage Slayer)">
                <description>Wenn eine Kreatur innerhalb von 1,50 m (5 feet) von Kenjiro einen Zauber wirkt, kann Kenjiro seine Reaktion verwenden, um einen Nahkampfangriff mit einer Waffe gegen sie auszuführen. Wenn Kenjiro einer Kreatur Schaden zufügt, die sich auf einen Zauber konzentriert, hat sie Nachteil auf ihren Rettungswurf, um die Konzentration aufrechtzuerhalten. Kenjiro hat Vorteil auf Rettungswürfe gegen Zauber, die von Kreaturen innerhalb von 1,50 m (5 feet) gewirkt werden.</description>
            </trait>
            <trait name="Kampfstil: Kampf mit Zweihänder">
                <description>Wenn Kenjiro bei einem Schadenswurf mit einer Nahkampfwaffe, die er mit beiden Händen führt, eine 1 oder 2 würfelt, kann er den Würfel einmal neu werfen. Er muss das neue Ergebnis verwenden. Die Waffe muss das Merkmal „Zweihändig“ oder „Vielseitig“ besitzen.</description>
            </trait>
            <trait name="Zusätzlicher Angriff (Extra Attack)">
                <description>Kenjiro kann zweimal angreifen, wenn er in seinem Zug die Angriffsaktion durchführt.</description>
            </trait>
            <trait name="Zauberwirken (Spellcasting)">
                <description>Kenjiro ist ein Zauberwirker der 5. Stufe. Sein Zauberattribut ist Intelligenz (Zauberrettungswurf SG 11, +3 auf Zauberangriffe).</description>
            </trait>
        </traits>
        <actions>
            <!-- Normale Aktionen, die der NSC in seinem Zug ausführen kann -->
            <action name="Mehrfachangriff">
                <description>Kenjiro führt zwei Angriffe mit seinem Großschwert aus.</description>
            </action>
            <action name="Tatendrang (Action Surge) (1/Kurze Rast)">
                <description>In seinem Zug kann Kenjiro eine zusätzliche Aktion ausführen, zusätzlich zu seiner regulären Aktion und einer möglichen Bonusaktion.</description>
            </action>
        </actions>
        <attacks>
            <!-- Einzelne Angriffe mit Trefferbonus, Reichweite und Schaden -->
            <attack name="Großschwert (Greatsword)">
                <type>Nahkampf</type>
                <bonus>+6</bonus>
                <range>1,50 m (5 feet)</range>
                <target>ein Ziel</target>
                <damage>10 (2W6 + 3) Hiebschaden</damage>
            </attack>
        </attacks>
        <reactions>
            <!-- Reaktionen, die durch einen klaren Trigger ausgelöst werden -->
            <reaction name="Schild (Shield)">
                <description>Reaktion: Wenn Kenjiro von einem Angriff getroffen oder von Magisches Geschoss anvisiert wird, erschafft er eine unsichtbare magische Barriere. Bis zum Beginn seines nächsten Zuges erhält er +5 auf seine RK, auch gegen den auslösenden Angriff, und erleidet keinen Schaden durch Magisches Geschoss.</description>
            </reaction>
        </reactions>
