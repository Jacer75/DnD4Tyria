                <spell id="ID_D4T_SPELL_DANCING_LIGHTS" level="0">Tanzende Lichter (Dancing Lights)</spell>
                <spell id="ID_D4T_SPELL_SHIELD" level="1">Schild (Shield)</spell>
                <spell id="ID_D4T_SPELL_THUNDERWAVE" level="1">Donnerwoge (Thunderwave)</spell>
                <spell id="ID_D4T_SPELL_MAGIC_MISSILE" level="1">Magisches Geschoss (Magic Missile)</spell>
                <spell id="ID_D4T_SPELL_FIND_FAMILIAR" level="1">Vertrauten finden (Find Familiar)</spell>
            </spelllist>
            <slots>
                <slot level="1" count="3"/>
            </slots>
        </spellcasting>
    </statblock>
