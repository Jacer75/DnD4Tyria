            <attackBonus>+6</attackBonus>
            <spelllist>
                <spell id="ID_D4T_SPELL_GUIDANCE" level="0">Göttliche Führung (Guidance)</spell>
                <spell id="ID_D4T_SPELL_LIGHT" level="0">Licht (Light)</spell>
                <spell id="ID_D4T_SPELL_THAUMATURGY" level="0">Thaumaturgie (Thaumaturgy)</spell>
                <spell id="ID_D4T_SPELL_SPARE_THE_DYING" level="0">Verschonung der Toten (Spare the Dying)</spell>
                <spell id="ID_D4T_SPELL_COMMAND" level="1">Befehl (Command)</spell>
                <spell id="ID_D4T_SPELL_HEALING_WORD" level="1">Heilendes Wort (Healing Word)</spell>
                <spell id="ID_D4T_SPELL_CHARM_PERSON" level="1">Person bezaubern (Charm Person)</spell>
                <spell id="ID_D4T_SPELL_DISGUISE_SELF" level="1">Selbstverkleidung (Disguise Self)</spell>
                <spell id="ID_D4T_SPELL_INFLICT_WOUNDS" level="1">Wunden verursachen (Inflict Wounds)</spell>
                <spell id="ID_D4T_SPELL_BLINDNESS_DEAFNESS" level="2">Blindheit/Taubheit (Blindness/Deafness)</spell>
                <spell id="ID_D4T_SPELL_HOLD_PERSON" level="2">Person festhalten (Hold Person)</spell>
                <spell id="ID_D4T_SPELL_LESSER_RESTORATION" level="2">Schwache Genesung (Lesser Restoration)</spell>
                <spell id="ID_D4T_SPELL_MIRROR_IMAGE" level="2">Spiegelbilder (Mirror Image)</spell>
                <spell id="ID_D4T_SPELL_PASS_WITHOUT_TRACE" level="2">Spurloses Gehen (Pass without Trace)</spell>
                <spell id="ID_D4T_SPELL_SILENCE" level="2">Stille (Silence)</spell>
