                <spell id="ID_D4T_SPELL_SENDING" level="3">Verständigung (Sending)</spell>
            </spelllist>
            <slots>
                <slot level="1" count="4"/>
                <slot level="2" count="3"/>
                <slot level="3" count="2"/>
            </slots>
        </spellcasting>
