        <saves>
            <save ability="Wis" bonus="+0"/>
        </saves>
        <!--<skills></skills>-->
        <traits>
            <trait name="Untote Zähigkeit">
                <description>
        Wenn Schaden den Zombie auf 0 Trefferpunkte reduziert, muss er einen Konstitutionsrettungswurf mit SG 5 + dem erlittenen Schaden bestehen, sofern der Schaden nicht durch einen kritischen Treffer oder Strahlenschaden verursacht wurde. Bei Erfolg fällt der Zombie stattdessen auf 1 Trefferpunkt zurück.
      </description>
            </trait>
        </traits>
        <!--<actions></actions>-->
        <attacks>
            <attack name="Hieb">
                <type>Nahkampf</type>
                <bonus>+3</bonus>
                <range>1,50 m</range>
                <target>ein Ziel</target>
                <damage>4 (1W6 + 1) Wuchtschaden</damage>
            </attack>
        </attacks>
