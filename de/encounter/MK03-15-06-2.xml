<statblock name="Auferstandener Mantelpriester" id="risen-mantle-cleric">
  <meta>
    <size>Mittel</size>
    <type>Untoter</type>
    <alignment>chaotisch böse</alignment>

    <ac>13</ac>

    <hp>33 (6W8 + 6)</hp>

    <speed>6 m</speed>

    <initiative>+0</initiative>

    <senses>Dunkelsicht 18 m, Passive Wahrnehmung 10</senses>

    <languages>Tyrianisch</languages>

    <challenge>2</challenge>

    <resistances></resistances>

    <immunities>Gift</immunities>

    <conditionImmunities>Bezaubert, Erschöpfung, Vergiftet</conditionImmunities>
  </meta>

  <abilities>
    <ability name="Str" score="11" bonus="+0"/>
    <ability name="Dex" score="10" bonus="+0"/>
    <ability name="Con" score="16" bonus="+3"/>
    <ability name="Int" score="10" bonus="+0"/>
    <ability name="Wis" score="13" bonus="+1"/>
    <ability name="Cha" score="12" bonus="+1"/>
  </abilities>

  <saves>
  </saves>

  <skills>
    <skill name="Religion" bonus="+2"/>
  </skills>

  <traits>
    <trait name="Untote Zähigkeit">
      <description>
        Wenn Schaden den Priester auf 0 Trefferpunkte reduziert, muss er einen Konstitutionsrettungswurf mit SG 5 + dem erlittenen Schaden bestehen, sofern der Schaden nicht durch einen kritischen Treffer oder Strahlenschaden verursacht wurde. Bei Erfolg fällt der Priester stattdessen auf 1 Trefferpunkt zurück.
      </description>
    </trait>

    <trait name="Dunkle Hingabe">
      <description>
        Der Priester hat Vorteil auf Rettungswürfe gegen Bezaubern und Furcht.
      </description>
    </trait>
  </traits>

  <actions>
    <action name="Mehrfachangriff">
      <description>
        Der Priester führt zwei Angriffe mit seinem Dolch aus.
      </description>
    </action>
  </actions>

  <attacks>
    <attack name="Dolch">
      <type>Nahkampf oder Fernkampf</type>
      <bonus>+3</bonus>
      <range>1,50 m oder 6/18 m</range>
      <target>eine Kreatur</target>
      <damage>4 (1W4 + 2) Stichschaden</damage>
    </attack>
  </attacks>

