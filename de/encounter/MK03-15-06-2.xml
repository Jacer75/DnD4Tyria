    <stat>Wis</stat>

    <saveDC>11</saveDC>

    <attackBonus>+3</attackBonus>

    <spelllist>
      <spell id="ID_D4T_SPELL_LIGHT" level="0">Licht</spell>
      <spell id="ID_D4T_SPELL_SACRED_FLAME" level="0">Heilige Flamme</spell>
      <spell id="ID_D4T_SPELL_THAUMATURGY" level="0">Thaumaturgie</spell>

      <spell id="ID_D4T_SPELL_COMMAND" level="1">Befehl (Command)</spell>
      <spell id="ID_D4T_SPELL_INFLICT_WOUNDS" level="1">Wunden verursachen (Inflict Wounds)</spell>
      <spell id="ID_D4T_SPELL_SHIELD_OF_FAITH" level="1">Schild des Glaubens (Shield of Faith)</spell>

      <spell id="ID_D4T_SPELL_HOLD_PERSON" level="2">Person festhalten (Hold Person)</spell>
      <spell id="ID_D4T_SPELL_SPIRITUAL_WEAPON" level="2">Waffe des Glaubens (Spiritual Weapon)</spell>
