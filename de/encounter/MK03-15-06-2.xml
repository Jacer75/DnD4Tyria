    <statblock name="Zombie" id="zombie">
        <meta>
            <size>Mittel</size>
            <type>Untoter</type>
            <alignment>neutral böse</alignment>
            <ac>8</ac>
            <hp>22 (3W8 + 9)</hp>
            <speed>6 m</speed>
            <initiative>-2</initiative>
            <senses>Dunkelsicht 18 m, Passive Wahrnehmung 8</senses>
            <languages>versteht die Sprachen, die er im Leben kannte, kann aber nicht sprechen</languages>
            <challenge>1/4</challenge>
            <resistances/>
